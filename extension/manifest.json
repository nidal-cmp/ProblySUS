{
    "manifest_version": 3,
    "name": "ProblySUS Scanner",
    "version": "1.0",
    "description": "Scans the current URL for potential scam risks using the local ProblySUS backend.",
    "permissions": [
        "activeTab",
        "scripting"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_title": "Scan this page",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "background": {
        "service_worker": "background.js"
    },
    "host_permissions": [
        "http://127.0.0.1:5000/*",
        "http://localhost:5000/*"
    ]
}